#!/usr/bin/env bash
# spy-ai — SpyAI: passive reconnaissance for AI-facing systems
set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly OUTPUT_DIR="${SCRIPT_DIR}/output"
readonly LOGS_DIR="${OUTPUT_DIR}/logs"
readonly DEFAULT_PROBE_PATHS="${SCRIPT_DIR}/data/passive_probes.txt"
readonly DEFAULT_INTERESTING_HEADERS="${SCRIPT_DIR}/data/interesting_headers.txt"
readonly SCAN_PORTS_PY="${SCRIPT_DIR}/lib/scan_ports.py"

# Common non-AI ports (compact set; use nmap separately for full sweeps).
readonly -a COMMON_PORTS=(
  22 25 53 135 139 445 3306 3389 5432 6379 27017
)

# HTTP-likely ports for AI-facing services
readonly -a HTTP_LIKELY_PORTS=(
  80 443 3000 3001 4000 5000 5601
  $(seq 8000 8080)
  8081 8443 8888 9000 9001 9200 11434
)

# Ports treated as HTTPS by default (in addition to service-name heuristics).
readonly -a HTTPS_PORTS=(443 8443 9200)

PROBE_PATHS=()
INTERESTING_HEADERS=()

readonly MAX_BODY_BYTES=8192        # bytes captured in exec log per response
readonly INLINE_BODY_BYTES=200      # bytes inlined into the report's Notes column
readonly CURL_MAX_TIME=5

TARGET=""
RUN_ID=""
ARTIFACT_BASE=""
PORTS_SCAN_LOG=""
REPORT_PATH=""
EXEC_LOG=""
WORK_DIR=""
STARTED_AT=""
FINISHED_AT=""
SERVICE_DATA=""
TLS_TIMEOUT_CMD=""

usage() {
  cat <<'EOF'
SpyAI — passive reconnaissance for AI-facing systems

Usage: spy-ai <IP|hostname>

Runs a lightweight TCP connect scan (python3) on AI-likely + common ports,
then HTTP fingerprinting, endpoint discovery, and TLS cert mining.

Outputs (relative to spy-ai/):
  output/<target>-<N>.md
  output/logs/<target>-<N>.exec.log

Required: python3, curl
Optional: openssl, timeout|gtimeout

For full port/version sweeps, run nmap separately and use this tool for AI HTTP discovery.
EOF
}

log_msg() { echo "$@" >&2; }
log_step() { log_msg "  $*"; }

WAIT_SPINNER_PID=""

readonly -a SPYAI_PHRASES=(
  "mapping the latent attack surface..."
  "listening for whispers on high ports..."
  "correlating OpenAPI ghosts in the wire..."
  "tracing RAG endpoints through the noise..."
  "fingerprinting inference daemons..."
  "harvesting TLS fingerprints from the void..."
  "parsing agent health beacons..."
  "following fetch() trails in minified JS..."
  "enumerating /v1/models without credentials..."
  "sweeping 8000-8080 for sleeping agents..."
  "decoding Server headers for AI backends..."
  "mining embedded paths from static HTML..."
  "watching uvicorn banners blink..."
  "cataloguing auth challenges on the perimeter..."
  "building the Markdown dossier..."
)

color_if_tty() {
  local code="$1"
  if [[ -t 2 ]]; then
    printf '\033[%sm' "$code"
  fi
}

color_reset() {
  color_if_tty 0
}

show_banner() {
  local c g d r
  c="$(color_if_tty 92)"
  g="$(color_if_tty 32)"
  w="$(color_if_tty 31)"
  r="$(color_reset)"
  cat >&2 <<BANNER
${c}
  ███████╗██████╗ ██╗   ██╗ █████╗ ██╗
